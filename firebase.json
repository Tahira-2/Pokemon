{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "config.js",
      "config.example.js",
      "API_S.env",
      "pokesearch-backup.html",
      "package.json",
      "package-lock.json",
      "README.md"
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      }
    ]
  }
}
